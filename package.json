{
  "name": "02-rtc-analysis-tools",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:app": "pnpm --filter @rtc/peer-analyst build",
    "build:server": "pnpm --filter @rtc/peer-analyst-dashboard build",
    "build": "pnpm -r build",
    "dev:app": "pnpm --filter @rtc/peer-analyst dev",
    "dev:server": "pnpm --filter @rtc/peer-analyst-dashboard dev",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.62.0"
  }
}
